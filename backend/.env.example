# Django settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# OpenAI LLM (обязательно для генерации контента)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_PROXY=http://your-proxy:8080  # Опционально

# ScrapeCreators API (для парсинга Instagram/TikTok/YouTube)
# Оставьте пустым или закомментируйте для использования моковых данных
# SCRAPECREATORS_API_KEY=your-api-key-here
# SCRAPECREATORS_API_BASE=https://api.scrapecreators.com

# Режим заглушки для тестирования без реального API
SCRAPECREATORS_USE_MOCK=true

# Redis/Celery
REDIS_URL=redis://localhost:6379/0

# PostgreSQL (для продакшена, в разработке используется SQLite)
# POSTGRES_DB=content_saas
# POSTGRES_USER=content_user
# POSTGRES_PASSWORD=content_pass
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
